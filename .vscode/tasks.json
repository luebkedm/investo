{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Investo",
            "type": "shell",
            "command": "mvn",
            "args": ["clean", "package", "-q"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$java"],
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "Run Investo",
            "type": "shell",
            "command": "mvn",
            "args": ["javafx:run"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": ["$java"],
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "mvn",
            "args": ["clean", "-q"],
            "group": "build",
            "problemMatcher": ["$java"]
        }
    ]
}
